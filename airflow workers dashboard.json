          "expr": "avg by (label_dag_id, label_task_id) (\n  container_memory_working_set_bytes{namespace=\"$namespace\", container=\"base\"}\n  * on(pod) group_left(label_dag_id, label_task_id)\n  kube_pod_labels{namespace=\"$namespace\", label_dag_id=~\"$dag_id\", label_task_id=~\"$task_id\", label_pod_size=~\"$pod_size\", label_dag_id!=\"\", label_task_id!=\"\"}\n)",
          "legendFormat": "{{label_dag_id}} / {{label_task_id}}",
          "refId": "A"
