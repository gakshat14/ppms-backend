  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Airflow worker pod right-sizing dashboard \u2014 which tasks are under/over-provisioned, which are OOM risk, what limits should be set.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "\ud83d\udea6 Fleet Health",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "type": "stat",
      "id": 1,
      "title": "OOM Kills",
      "description": "Total OOM kills in the selected time window. Any value > 0 means at least one task was killed due to memory exhaustion \u2014 its memory limit is too low for its peak usage.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(\n  increase(kube_pod_container_status_restarts_total{namespace=\"$namespace\", container=\"base\"}[$__range])\n  * on(pod) group_left()\n  kube_pod_container_status_last_terminated_reason{namespace=\"$namespace\", container=\"base\", reason=\"OOMKilled\"}\n  * on(pod) group_left()\n  kube_pod_labels{namespace=\"$namespace\", label_dag_id=~\"$dag_id\", label_task_id=~\"$task_id\", label_pod_size=~\"$pod_size\", label_dag_id!=\"\", label_task_id!=\"\"}\n) or vector(0)",
          "legendFormat": "OOM Kills",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "type": "stat",
      "id": 2,
      "title": "Under-provisioned Tasks",
      "description": "Tasks where peak memory > 80% of their memory limit. These are at OOM risk \u2014 their limit needs to be raised or they need a larger pod size.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "count(\n  max by (label_dag_id, label_task_id) (\n  container_memory_working_set_bytes{namespace=\"$namespace\", container=\"base\"}\n  * on(pod) group_left(label_dag_id, label_task_id)\n  kube_pod_labels{namespace=\"$namespace\", label_dag_id=~\"$dag_id\", label_task_id=~\"$task_id\", label_pod_size=~\"$pod_size\", label_dag_id!=\"\", label_task_id!=\"\"}\n)\n  / avg by (label_dag_id, label_task_id) (\n  kube_pod_container_resource_limits{namespace=\"$namespace\", container=\"base\", resource=\"memory\"}\n  * on(pod) group_left(label_dag_id, label_task_id)\n  kube_pod_labels{namespace=\"$namespace\", label_dag_id=~\"$dag_id\", label_task_id=~\"$task_id\", label_pod_size=~\"$pod_size\", label_dag_id!=\"\", label_task_id!=\"\"}\n) * 100 > 80\n) or vector(0)",
          "legendFormat": "Under-provisioned",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "type": "stat",
      "id": 3,
      "title": "Over-provisioned Tasks",
      "description": "Tasks where average memory < 20% of their memory limit. These are wasting cluster resources \u2014 they could run on a smaller pod size or have their limit reduced.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "count(\n  avg by (label_dag_id, label_task_id) (\n  container_memory_working_set_bytes{namespace=\"$namespace\", container=\"base\"}\n  * on(pod) group_left(label_dag_id, label_task_id)\n  kube_pod_labels{namespace=\"$namespace\", label_dag_id=~\"$dag_id\", label_task_id=~\"$task_id\", label_pod_size=~\"$pod_size\", label_dag_id!=\"\", label_task_id!=\"\"}\n)\n  / avg by (label_dag_id, label_task_id) (\n  kube_pod_container_resource_limits{namespace=\"$namespace\", container=\"base\", resource=\"memory\"}\n  * on(pod) group_left(label_dag_id, label_task_id)\n  kube_pod_labels{namespace=\"$namespace\", label_dag_id=~\"$dag_id\", label_task_id=~\"$task_id\", label_pod_size=~\"$pod_size\", label_dag_id!=\"\", label_task_id!=\"\"}\n) * 100 < 20\n) or vector(0)",
          "legendFormat": "Over-provisioned",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "type": "stat",
      "id": 4,
      "title": "Active Worker Pods",
      "description": "Total worker pods currently running with a base container and valid dag_id + task_id labels.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "count(\n  container_memory_working_set_bytes{namespace=\"$namespace\", container=\"base\"}\n  * on(pod) group_left()\n  kube_pod_labels{namespace=\"$namespace\", label_dag_id=~\"$dag_id\", label_task_id=~\"$task_id\", label_pod_size=~\"$pod_size\", label_dag_id!=\"\", label_task_id!=\"\"}\n) or vector(0)",
          "legendFormat": "Active Pods",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 101,
      "title": "\ud83c\udfaf Right-Sizing Table \u2014 Tasks Needing Attention",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "type": "timeseries",
      "id": 10,
      "title": "Fleet Memory Usage by Pod Size \u2014 Stacked",
      "description": "Total memory consumed per pod size, stacked. The height of each coloured band shows how much that pod size contributes to overall fleet memory. Pods with no pod_size label are grouped as 'unknown'.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Memory",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 60,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "avg by (label_pod_size) (\n  container_memory_working_set_bytes{namespace=\"$namespace\", container=\"base\"}\n  * on(pod) group_left(label_pod_size)\n  label_replace(\n  kube_pod_labels{namespace=\"$namespace\", label_dag_id=~\"$dag_id\", label_task_id=~\"$task_id\", label_pod_size=~\"$pod_size\", label_dag_id!=\"\", label_task_id!=\"\"},\n  \"label_pod_size\", \"unknown\", \"label_pod_size\", \"^$\"\n)\n)",
          "legendFormat": "{{label_pod_size}}",
          "refId": "A"
        }
      ]
    },
    {
